{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/markdown-graph/schema/edge.schema.json",
  "title": "Transform Edge",
  "description": "A directed edge representing a conversation/transformation between documents",
  "type": "object",
  "required": ["id", "sources", "targets", "transform"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the edge"
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 0,
      "description": "Input node IDs (empty for creation from scratch)"
    },
    "targets": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Output node IDs"
    },
    "prompt_nodes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Prompt document node IDs (separate from input sources for clarity)"
    },
    "transform": {
      "$ref": "#/definitions/Transform"
    },
    "context": {
      "type": "string",
      "description": "Additional context or system prompt summary"
    },
    "session_id": {
      "type": "string",
      "description": "Session identifier for grouping edges in a conversation session"
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Edge IDs that this edge supersedes (undo/retry chain)"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1,
      "description": "Attempt number for retries (optional, for readability)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the transformation was performed"
    },
    "metadata": {
      "type": "object",
      "description": "Additional arbitrary metadata",
      "additionalProperties": true
    },
    "review": {
      "$ref": "review.schema.json",
      "description": "User review and QA record for this edge's output"
    },
    "analytics": {
      "$ref": "analytics.schema.json",
      "description": "Adoption and quality analytics"
    },
    "template_ref": {
      "type": "string",
      "description": "Template ID if this edge was created from a template"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Transform": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "extract", "expand", "create", "rewrite",
            "merge", "compare", "compress", "split",
            "translate", "format", "annotate",
            "analyze", "project", "decide", "decompose", "verify",
            "chain", "custom"
          ],
          "description": "Type of transformation"
        },
        "description": {
          "type": "string",
          "description": "Directional description of this conversation round"
        },
        "agent": {
          "type": "string",
          "description": "Agent used (e.g. copilot, cursor, custom)"
        },
        "model": {
          "type": "string",
          "description": "Model used (e.g. claude-opus-4, gpt-4o)"
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Skills / plugins invoked"
        },
        "prompt_summary": {
          "type": "string",
          "description": "Brief summary of the prompt (not the full prompt)"
        }
      },
      "additionalProperties": false
    }
  }
}
