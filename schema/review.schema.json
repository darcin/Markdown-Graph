{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/markdown-graph/schema/review.schema.json",
  "title": "Review Record",
  "description": "User review and QA record for an edge's output",
  "type": "object",
  "required": ["status"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["accepted", "revised", "rejected"],
      "description": "Overall review status"
    },
    "revision_notes": {
      "type": "string",
      "description": "Notes on what was revised and why"
    },
    "qa": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["q", "a"],
        "properties": {
          "q": { "type": "string", "description": "User question" },
          "a": { "type": "string", "description": "AI or user answer" }
        },
        "additionalProperties": false
      },
      "description": "Question-answer pairs from the review process"
    },
    "final_action": {
      "type": "string",
      "enum": ["accepted", "revised_and_accepted", "rejected"],
      "description": "Final action taken after review"
    }
  },
  "additionalProperties": false
}
